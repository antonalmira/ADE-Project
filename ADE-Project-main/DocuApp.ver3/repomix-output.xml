                                            img.save(temp_image, "PNG", quality=95)
                                        print(f"Exported chart {sheet_name} with Method 1 to {temp_image}")
                                        success = True
                                        break
                                    except Exception as e:
                                        if attempt < 2:
                                            time.sleep(1)
                                            print(f"Retry {attempt + 1} for Method 1 ({sheet_name}): {str(e)}")
